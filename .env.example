# World Cup 2026 API Configuration
# API Documentation: https://worldcup26.ir/api-docs/
# GitHub: https://github.com/rezarahiminia/worldcup2026

# ⚠️ IMPORTANT: The public World Cup 2026 API does NOT require authentication
# The endpoints at https://worldcup26.ir are free and open for read-only access
# You can use the API without any token or login!

# World Cup 2026 API Base URL
WORLDCUP_API_URL=https://worldcup26.ir

# Authentication (Optional - not needed for public endpoints)
# The following are only needed if you self-host the API
# WORLDCUP_API_TOKEN=your_jwt_token_here
# WORLDCUP_API_EMAIL=your_email@example.com
# WORLDCUP_API_PASSWORD=your_password_here

# Optional: Cache duration in seconds (default: 3600 = 1 hour)
WORLDCUP_CACHE_DURATION=3600

# Optional: Enable API debug logging (default: false)
WORLDCUP_API_DEBUG=false
